{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "outDir": "out-e2e",
    "rootDir": "test-e2e",
    "lib": ["ES2020"],
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "mocha"]
  },
  "include": ["test-e2e/**/*"]
}
